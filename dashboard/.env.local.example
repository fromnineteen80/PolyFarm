# Supabase — same project as the bot
# Get from supabase.com → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://yourproject.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# NextAuth — generate secret with any random string
# or visit generate-secret.vercel.app
NEXTAUTH_SECRET=your_random_secret_here
NEXTAUTH_URL=https://polyfarm.vercel.app

# Google OAuth
# Setup at console.cloud.google.com
# Create project → OAuth 2.0 credentials → Web app
# Add redirect URI: https://your-vercel-url/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Comma-separated list of authorized Gmail addresses
GOOGLE_AUTHORIZED_EMAILS=investor1@gmail.com,investor2@gmail.com
