# Polymarket US API
# Generate at polymarket.us/developer
# Secret shown only once — copy immediately
POLYMARKET_KEY_ID=your_key_id_here
POLYMARKET_SECRET_KEY=your_secret_key_here

# The Odds API — the-odds-api.com
# Use the $79/month plan (100,000 credits/month)
# Sharp reference: consensus from US books
# (DraftKings, FanDuel, BetMGM, Caesars, etc.)
# Docs: the-odds-api.com/liveapi/guides/v4/
ODDS_API_KEY=your_key_here

# Telegram — create bot via @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_numeric_chat_id_here

# Supabase — create project at supabase.com
# Use the anon/public key not the service_role key
# Run data/migrations/001_initial_schema.sql in
# Supabase SQL editor before first bot startup
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_KEY=your_anon_key_here

# Trading mode
# Keep PAPER_MODE=true until 50 paper trades complete
PAPER_MODE=true
PHASE2_CRYPTO_ENABLED=false
PHASE1B_RESEARCH_ENABLED=false

# Environment
LOG_LEVEL=INFO
